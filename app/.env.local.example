# Copy to .env.local — filled automatically when you run `npx convex dev`
NEXT_PUBLIC_CONVEX_URL=

# ── The following are CONVEX server env vars ──
# Set them with:  npx convex env set NAME value
#
# TELEGRAM_BOT_TOKEN   → from @BotFather on Telegram
# TELEGRAM_CHAT_ID     → your chat/group id (see README)
# ADMIN_PASSWORD       → password for the /admin dashboard
# SITE_URL             → deployed site url, e.g. https://lacheatandsmile.vercel.app
